{
    "name": "scummvm",
    "display_name": "ScummVM",
    "description": "Run classic adventure games using ScummVM",
    "version": "2.0.2",
    "author": "luducat",
    "min_luducat_version": "0.2.9.24",
    "plugin_types": ["platform"],
    "entry_point": "provider.ScummVMProvider",
    "enabled_by_default": true,
    "capabilities": {
        "runtime_type": "scummvm",
