#: luducat/ui/dialogs/tag_manager_dialog.py:800
#, python-brace-format
msgid ""
"Are you sure you want to delete the tag '{name}'?\n"
"\n"
"This will remove it from all games."
msgstr ""
"Voulez-vous vraiment supprimer le tag \"{name}\" ?\n"
"\n"
"Il sera retiré de tous les jeux."

#: luducat/ui/dialogs/tag_manager_dialog.py:991
#: luducat/ui/dialogs/tag_manager_dialog.py:998
#: luducat/ui/dialogs/tag_manager_dialog.py:1005
msgid "Merge Tags"
msgstr "Fusionner les tags"

#: luducat/ui/dialogs/tag_manager_dialog.py:991
msgid "Need at least two tags to merge."
msgstr "Il faut au moins deux tags pour fusionner."

#: luducat/ui/dialogs/tag_manager_dialog.py:998
msgid "Tag to keep:"
msgstr "Tag à conserver :"

#: luducat/ui/dialogs/tag_manager_dialog.py:1005
#, python-brace-format
msgid "Tag to merge into '{name}':"
msgstr "Tag à fusionner dans \"{name}\" :"

#: luducat/ui/dialogs/tag_manager_dialog.py:1014
msgid "Confirm Merge"
msgstr "Confirmer la fusion"

#: luducat/ui/dialogs/tag_manager_dialog.py:1015
#, python-brace-format
msgid ""
"Merge '{absorb}' into '{keep}'?\n"
"\n"
"All games tagged '{absorb}' will be retagged '{keep}'.\n"
"'{absorb}' will be deleted."
msgstr ""
"Fusionner \"{absorb}\" dans \"{keep}\" ?\n"
"\n"
"Tous les jeux marqués \"{absorb}\" seront re-marqués \"{keep}\".\n"
"\"{absorb}\" sera supprimé."

#: luducat/ui/dialogs/tag_manager_dialog.py:1029
msgid "Merge Failed"
msgstr "Échec de la fusion"

#: luducat/ui/dialogs/tag_manager_dialog.py:1037
msgid "Export Tags"
msgstr "Exporter les tags"

#: luducat/ui/dialogs/tag_manager_dialog.py:1048
#, python-brace-format
msgid "Exported {count} tags to {path}"
msgstr "{count} tags exportés vers {path}"

#: luducat/ui/dialogs/tag_manager_dialog.py:1058
msgid "Import Tags"
msgstr "Importer des tags"

#: luducat/ui/dialogs/tag_manager_dialog.py:1087
#, python-brace-format
msgid ""
"The file does not contain a tag list.\n"
"\n"
"Expected a JSON array like:\n"
"[{\"name\": \"My Tag\", \"color\": DEFAULT_TAG_COLOR}, ...]"
msgstr ""
"Le fichier ne contient pas de liste de tags.\n"
"\n"
"Un tableau JSON de ce type est attendu :\n"
"[{\"name\": \"Mon tag\", \"color\": DEFAULT_TAG_COLOR}, ...]"

#: luducat/ui/dialogs/tag_manager_dialog.py:1104
msgid "Import Warning"
msgstr "Avertissement d'importation"

#: luducat/ui/dialogs/tag_manager_dialog.py:1105
#, python-brace-format
msgid ""
"Some entries in the file have problems and will be skipped:\n"
"\n"
"{details}{suffix}\n"
"\n"
"Each entry needs at least a \"name\" field.\n"
"Continue importing the valid entries?"
msgstr ""
"Certaines entrées du fichier posent problème et seront ignorées :\n"
"\n"
"{details}{suffix}\n"
"\n"
"Chaque entrée doit avoir au moins un champ \"name\".\n"
"Continuer l'importation des entrées valides ?"

