#: luducat/main.py:538
#, python-brace-format
msgid "{app} — Directory Permissions"
msgstr "{app} -- Permissions des répertoires"

#: luducat/main.py:539
#, python-brace-format
msgid ""
"{app}'s configuration, databases, and caches were accessible to other "
"users on this system:\n"
"\n"
"{dirs}\n"
"\n"
"Permissions have been secured so that only your login account and {app} "
"itself have access."
msgstr ""
"La configuration, les bases de données et les caches de {app} étaient "
"accessibles aux autres utilisateurs de ce système :\n"
"\n"
"{dirs}\n"
"\n"
"Les permissions ont été sécurisées pour que seul votre compte utilisateur"
" et {app} aient accès."

