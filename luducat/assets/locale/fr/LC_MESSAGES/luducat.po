#, python-brace-format
msgid "Welcome to {app_name}!"
msgstr "Bienvenue dans {app_name} !"

#: luducat/ui/dialogs/setup_wizard.py:156
#: luducat/ui/dialogs/setup_wizard.py:241
msgid ""
"Browse all your game libraries in one place — covers, ratings, "
"compatibility data, powerful filters, tag and favorite import, offline-"
"capable, and fully private with no telemetry."
msgstr ""
"Parcourez toutes vos bibliothèques de jeux en un seul endroit — "
"jaquettes, notes, données de compatibilité, filtres puissants, import de "
"tags et favoris, utilisable hors ligne et entièrement privé sans "
"télémétrie."

#: luducat/ui/dialogs/setup_wizard.py:164
#: luducat/ui/dialogs/setup_wizard.py:246
msgid ""
"Browse, organize, and explore — launching is handled by your platform's "
"native launcher."
msgstr ""
"Parcourez, organisez et explorez -- le lancement est gere par le lanceur "
"natif de votre plateforme."

#: luducat/ui/dialogs/setup_wizard.py:185
#: luducat/ui/dialogs/setup_wizard.py:251
msgid "Change the display language for the entire application"
msgstr "Changer la langue d'affichage pour toute l'application"

#: luducat/ui/dialogs/setup_wizard.py:214
#: luducat/ui/dialogs/setup_wizard.py:253
msgid "Quick Setup:"
msgstr "Configuration rapide :"

#: luducat/ui/dialogs/setup_wizard.py:220
#: luducat/ui/dialogs/setup_wizard.py:255
#, python-brace-format
msgid ""
"{app_name} pre-configures backups, a default theme, and update checks. "
"You will still choose your game stores and enter credentials. Consent is "
"required for reading browser cookies and local launcher data (tags, "
"favorites, playtime) from other applications on your machine."
msgstr ""
"{app_name} préconfigure les sauvegardes, un thème par défaut et les "
"vérifications de mises à jour. Vous choisirez tout de même vos boutiques "
"et saisirez vos identifiants. Votre consentement est requis pour lire les"
" cookies du navigateur et les données locales des lanceurs (tags, "
"favoris, temps de jeu) des autres applications sur votre machine."

#: luducat/ui/dialogs/setup_wizard.py:226
#: luducat/ui/dialogs/setup_wizard.py:261
msgid "No, full wizard"
msgstr "Non, assistant complet"

#: luducat/ui/dialogs/setup_wizard.py:227
#: luducat/ui/dialogs/setup_wizard.py:262
msgid "Yes, use defaults (recommended)"
msgstr "Oui, utiliser les valeurs par défaut (recommandé)"

#: luducat/ui/dialogs/setup_wizard.py:303
#: luducat/ui/dialogs/setup_wizard.py:422
msgid "Data Access"
msgstr "Accès aux données"

#: luducat/ui/dialogs/setup_wizard.py:305
#: luducat/ui/dialogs/setup_wizard.py:424
msgid "Grant permission to read local data from your browsers and game launchers"
msgstr "Autoriser la lecture des données locales de vos navigateurs et lanceurs de jeux"
"Accorder la permission de lire les données locales de vos navigateurs et "
"lanceurs de jeux"

#: luducat/ui/dialogs/setup_wizard.py:323
#: luducat/ui/dialogs/setup_wizard.py:430
#, python-brace-format
msgid ""
"{app_name} reads your browser's store login cookies for authentication "
"and imports tags, favorites, playtime, and install status from Steam, GOG"
" Galaxy, Heroic, and other launchers on your machine. All data stays "
"local. You can change this anytime in Settings → Privacy."
msgstr ""
"{app_name} lit les cookies de connexion aux boutiques de votre navigateur"
" pour l'authentification et importe les tags, favoris, temps de jeu et "
"statut d'installation depuis Steam, GOG Galaxy, Heroic et les autres "
"lanceurs sur votre machine. Toutes les données restent locales. Vous "
"pouvez modifier cela à tout moment dans Paramètres → Confidentialité."

#: luducat/ui/dialogs/setup_wizard.py:384
#: luducat/ui/dialogs/setup_wizard.py:440
msgid "Hide adult-rated games from library"
msgstr "Masquer les jeux pour adultes de la bibliothèque"

#: luducat/ui/dialogs/setup_wizard.py:387
#: luducat/ui/dialogs/setup_wizard.py:442
msgid ""
"Uses confidence scoring from multiple sources (age ratings, content "
"descriptors) to identify adult content. You can change this later in "
"Settings → Advanced."
msgstr ""
"Utilise un score de confiance provenant de plusieurs sources "
"(classifications d'âge, descripteurs de contenu) pour identifier le "
"contenu pour adultes. Vous pouvez modifier cela plus tard dans Paramètres"
" → Avancé."

