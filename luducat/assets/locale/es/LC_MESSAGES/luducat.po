#: luducat/main.py:538
#, python-brace-format
msgid "{app} — Directory Permissions"
msgstr "{app} -- Permisos de directorio"

#: luducat/main.py:539
#, python-brace-format
msgid ""
"{app}'s configuration, databases, and caches were accessible to other "
"users on this system:\n"
"\n"
"{dirs}\n"
"\n"
"Permissions have been secured so that only your login account and {app} "
"itself have access."
msgstr ""
"La configuración, las bases de datos y las cachés de {app} eran "
"accesibles para otros usuarios de este sistema:\n"
"\n"
"{dirs}\n"
"\n"
"Los permisos han sido asegurados para que solo su cuenta de usuario y "
"{app} tengan acceso."

