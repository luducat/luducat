msgid "Directory Problem"
msgstr "Problema de directorio"

#: luducat/main.py:568
#, python-brace-format
msgid ""
"{label} is not usable:\n"
"{path}\n"
"\n"
"{error}\n"
"\n"
"The application may not work correctly."
msgstr ""
"{label} no se puede utilizar:\n"
"{path}\n"
"\n"
"{error}\n"
"\n"
"La aplicación podría no funcionar correctamente."

