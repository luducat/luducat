#: luducat/ui/dialogs/setup_wizard.py:151
#: luducat/ui/dialogs/setup_wizard.py:238
#, python-brace-format
msgid "Welcome to {app_name}!"
msgstr "Benvenuto in {app_name}!"

#: luducat/ui/dialogs/setup_wizard.py:156
#: luducat/ui/dialogs/setup_wizard.py:241
msgid ""
"Browse all your game libraries in one place — covers, ratings, "
"compatibility data, powerful filters, tag and favorite import, offline-"
"capable, and fully private with no telemetry."
msgstr ""
"Esplora tutte le tue librerie di giochi in un unico posto — copertine, "
"valutazioni, dati di compatibilità, filtri potenti, importazione di tag e"
" preferiti, utilizzabile offline e completamente privato senza "
"telemetria."

#: luducat/ui/dialogs/setup_wizard.py:164
#: luducat/ui/dialogs/setup_wizard.py:246
msgid ""
"Browse, organize, and explore — launching is handled by your platform's "
"native launcher."
msgstr ""
"Sfogliare, organizzare ed esplorare — l'avvio è gestito dal launcher "
"nativo della piattaforma."

#: luducat/ui/dialogs/setup_wizard.py:185
#: luducat/ui/dialogs/setup_wizard.py:251
msgid "Change the display language for the entire application"
msgstr "Cambiare la lingua di visualizzazione dell'intera applicazione"

#: luducat/ui/dialogs/setup_wizard.py:214
#: luducat/ui/dialogs/setup_wizard.py:253
msgid "Quick Setup:"
msgstr "Configurazione rapida:"

#: luducat/ui/dialogs/setup_wizard.py:220
#: luducat/ui/dialogs/setup_wizard.py:255
#, python-brace-format
msgid ""
"{app_name} pre-configures backups, a default theme, and update checks. "
"You will still choose your game stores and enter credentials. Consent is "
"required for reading browser cookies and local launcher data (tags, "
"favorites, playtime) from other applications on your machine."
msgstr ""
"{app_name} preconfigura i backup, un tema predefinito e i controlli degli"
" aggiornamenti. Potrai comunque scegliere i tuoi store e inserire le "
"credenziali. È necessario il consenso per leggere i cookie del browser e "
"i dati locali dei launcher (tag, preferiti, tempo di gioco) delle altre "
"applicazioni sul tuo computer."

#: luducat/ui/dialogs/setup_wizard.py:226
#: luducat/ui/dialogs/setup_wizard.py:261
msgid "No, full wizard"
msgstr "No, procedura guidata completa"

#: luducat/ui/dialogs/setup_wizard.py:227
#: luducat/ui/dialogs/setup_wizard.py:262
msgid "Yes, use defaults (recommended)"
msgstr "Sì, usa i valori predefiniti (consigliato)"

#: luducat/ui/dialogs/setup_wizard.py:303
#: luducat/ui/dialogs/setup_wizard.py:422
msgid "Data Access"
msgstr "Accesso ai dati"

#: luducat/ui/dialogs/setup_wizard.py:305
#: luducat/ui/dialogs/setup_wizard.py:424
msgid "Grant permission to read local data from your browsers and game launchers"
msgstr "Concedere il permesso di leggere i dati locali dai browser e dai launcher di giochi"
"Concedi il permesso di leggere i dati locali dai tuoi browser e launcher "
"di giochi"

#: luducat/ui/dialogs/setup_wizard.py:323
#: luducat/ui/dialogs/setup_wizard.py:430
#, python-brace-format
msgid ""
"{app_name} reads your browser's store login cookies for authentication "
"and imports tags, favorites, playtime, and install status from Steam, GOG"
" Galaxy, Heroic, and other launchers on your machine. All data stays "
"local. You can change this anytime in Settings → Privacy."
msgstr ""
"{app_name} legge i cookie di accesso agli store del tuo browser per "
"l'autenticazione e importa tag, preferiti, tempo di gioco e stato di "
"installazione da Steam, GOG Galaxy, Heroic e altri launcher sul tuo "
"computer. Tutti i dati restano locali. Puoi modificare questa "
"impostazione in qualsiasi momento in Impostazioni → Privacy."

#: luducat/ui/dialogs/setup_wizard.py:384
#: luducat/ui/dialogs/setup_wizard.py:440
msgid "Hide adult-rated games from library"
msgstr "Nascondere i giochi per adulti dalla libreria"

#: luducat/ui/dialogs/setup_wizard.py:387
#: luducat/ui/dialogs/setup_wizard.py:442
msgid ""
"Uses confidence scoring from multiple sources (age ratings, content "
"descriptors) to identify adult content. You can change this later in "
"Settings → Advanced."
msgstr ""
"Utilizza un punteggio di confidenza da più fonti (classificazioni per "
"età, descrittori di contenuto) per identificare il contenuto per adulti. "
"È possibile modificare questa impostazione in seguito in Impostazioni → "
"Avanzate."

#: luducat/ui/dialogs/setup_wizard.py:399
msgid "Your data stays on your machine"
msgstr "I tuoi dati restano sul tuo computer"

#: luducat/ui/dialogs/setup_wizard.py:400
msgid ""
"All game data, settings, and metadata are stored locally. No accounts, no"
" cloud, no tracking."
msgstr ""
"Tutti i dati dei giochi, le impostazioni e i metadati sono memorizzati "
"localmente. Nessun account, nessun cloud, nessun tracciamento."

#: luducat/ui/dialogs/setup_wizard.py:405
msgid "How store connections work"
msgstr "Come funzionano le connessioni agli store"

#: luducat/ui/dialogs/setup_wizard.py:406
msgid ""
"Store plugins access your game libraries via official APIs or browser "
"cookies for authentication. You provide API keys yourself; cookies are "
"read from your browser with your consent above."
msgstr ""
"I plugin degli store accedono alle tue librerie di giochi tramite API "
"ufficiali o cookie del browser per l'autenticazione. Le chiavi API le "
"fornisci tu; i cookie vengono letti dal tuo browser con il tuo consenso "
"sopra indicato."

#: luducat/ui/dialogs/setup_wizard.py:413
msgid "Game info from public sources"
msgstr "Informazioni sui giochi da fonti pubbliche"

#: luducat/ui/dialogs/setup_wizard.py:414
msgid ""
"Game information (genres, ratings, screenshots, compatibility) comes from"
" public databases via a privacy-respecting proxy. The proxy sees only "
"game IDs, never your identity."
msgstr ""
"Le informazioni sui giochi (generi, valutazioni, screenshot, "
"compatibilità) provengono da database pubblici tramite un proxy "
"rispettoso della privacy. Il proxy vede solo gli ID dei giochi, mai la "
"tua identità."

