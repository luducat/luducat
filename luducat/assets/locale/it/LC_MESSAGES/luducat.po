#: luducat/ui/dialogs/setup_wizard.py:424
msgid "Allow access to browser cookies and local game launcher data"
msgstr "Consentire l'accesso ai cookie del browser e ai dati locali dei launcher"

#: luducat/ui/dialogs/settings.py:3687
msgid ""
"Required for GOG browser login, Steam VDF import, and Heroic tag/favourite "
"sync"
msgstr ""
"Necessario per il login GOG tramite browser, l'importazione VDF di Steam e "
"la sincronizzazione tag/preferiti di Heroic"

#: luducat/ui/dialogs/settings.py:3696
#, python-brace-format
msgid ""
"Lets {app_name} read browser cookies to log into game stores, and import "
"tags, favorites, and playtime from local launchers (Steam, GOG Galaxy, "
"Heroic). Nothing is sent anywhere — all imported data stays on your "
"computer."
msgstr ""
"Permette a {app_name} di leggere i cookie del browser per accedere ai negozi"
" di giochi e importare tag, preferiti e tempo di gioco dai launcher locali "
"(Steam, GOG Galaxy, Heroic). Niente viene inviato da nessuna parte — tutti i"
" dati importati restano sul tuo computer."

#: luducat/ui/dialogs/settings.py:3709
msgid "Your Data"
msgstr "I tuoi dati"

#: luducat/ui/dialogs/settings.py:3714
msgid "Everything stays on your computer — game data, settings, metadata, all of it"
msgstr "Tutto resta sul tuo computer — dati di gioco, impostazioni, metadati, tutto"

#: luducat/ui/dialogs/settings.py:3716
#, python-brace-format
msgid "No account needed — {app_name} has no server, no cloud, no tracking"
msgstr ""
"Nessun account necessario — {app_name} non ha server, né cloud, né "
"tracciamento"

#: luducat/ui/dialogs/settings.py:3718
msgid "Nothing goes online unless you turn on a feature that needs it"
msgstr "Niente va online a meno che tu non attivi una funzione che lo richiede"

#: luducat/ui/dialogs/settings.py:3720
msgid "Passwords and API keys are kept in your system's secure storage (keyring)"
msgstr ""
"Le password e le chiavi API sono conservate nell'archivio sicuro del sistema"
" (keyring)"

#: luducat/ui/dialogs/settings.py:3722
msgid "Browser cookies are only read, never changed or copied"
msgstr "I cookie del browser vengono solo letti, mai modificati o copiati"

#: luducat/ui/dialogs/settings.py:3733
msgid "Online Features"
msgstr "Funzionalità online"

#: luducat/ui/dialogs/settings.py:3738
#, python-brace-format
msgid ""
"When you enable store or metadata plugins, {app_name} connects to these "
"services to fetch game information:"
msgstr ""
"Quando attivi plugin di negozio o metadati, {app_name} si connette a questi "
"servizi per recuperare informazioni sui giochi:"

#: luducat/ui/dialogs/settings.py:3757 luducat/ui/dialogs/settings.py:3758
msgid "none enabled"
msgstr "nessuno attivato"

#: luducat/ui/dialogs/settings.py:3761
#, python-brace-format
msgid "<b>Game stores</b> — {stores} (using your credentials)"
msgstr "<b>Negozi di giochi</b> — {stores} (con le tue credenziali)"

#: luducat/ui/dialogs/settings.py:3763
#, python-brace-format
msgid "<b>Game databases</b> — {databases}"
msgstr "<b>Database di giochi</b> — {databases}"

#: luducat/ui/dialogs/settings.py:3765
#, python-brace-format
msgid "<b>Update check</b> — checks for new {app_name} versions"
msgstr "<b>Controllo aggiornamenti</b> — cerca nuove versioni di {app_name}"

#: luducat/ui/dialogs/settings.py:3776
msgid ""
"IGDB access goes through a free proxy on Cloudflare. You can use your own "
"Twitch API credentials instead if you prefer (see Plugins tab)."
msgstr ""
"L'accesso a IGDB passa attraverso un proxy gratuito su Cloudflare. Puoi "
"usare le tue credenziali API Twitch se preferisci (vedi la scheda Plugin)."

#: luducat/ui/dialogs/settings.py:3785
msgid ""
"You can disable any of these in the Plugins tab, or go fully offline with "
"the offline toggle in the bottom-right corner of the main window."
msgstr ""
"Puoi disattivare tutto questo nella scheda Plugin, oppure passare "
"completamente offline con il pulsante nell'angolo in basso a destra della "
"finestra principale."

