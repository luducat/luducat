#: luducat/main.py:535
#, python-brace-format
msgid "{app} — Directory Permissions"
msgstr "{app} -- Permessi delle directory"

#: luducat/main.py:536
#, python-brace-format
msgid ""
"{app}'s configuration, databases, and caches were accessible to other users "
"on this system:\n"
"\n"
"{dirs}\n"
"\n"
"Permissions have been secured so that only your login account and {app} "
"itself have access."
msgstr ""
"La configurazione, i database e le cache di {app} erano accessibili ad altri"
" utenti di questo sistema:\n"
"\n"
"{dirs}\n"
"\n"
"I permessi sono stati messi in sicurezza in modo che solo il proprio account"
" utente e {app} abbiano accesso."

