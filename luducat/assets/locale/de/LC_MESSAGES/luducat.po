#: luducat/main.py:538
#, python-brace-format
msgid "{app} — Directory Permissions"
msgstr "{app} -- Verzeichnisberechtigungen"

#: luducat/main.py:539
#, python-brace-format
msgid ""
"{app}'s configuration, databases, and caches were accessible to other "
"users on this system:\n"
"\n"
"{dirs}\n"
"\n"
"Permissions have been secured so that only your login account and {app} "
"itself have access."
msgstr ""
"Konfiguration, Datenbanken und Caches von {app} waren für andere Benutzer"
" auf diesem System zugänglich:\n"
"\n"
"{dirs}\n"
"\n"
"Die Berechtigungen wurden gesichert, sodass nur Ihr Benutzerkonto und "
"{app} selbst Zugriff haben."

